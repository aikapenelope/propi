# Database (PgBouncer for runtime, direct Postgres for migrations)
DATABASE_URL=postgresql://platform:PASSWORD@10.0.1.20:6432/propi
DATABASE_DIRECT_URL=postgresql://platform:PASSWORD@10.0.1.20:5432/propi

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# MinIO / S3 Storage
S3_ENDPOINT=http://10.0.1.20:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_MEDIA_BUCKET=propi-media
S3_DOCS_BUCKET=propi-documents

# SMTP (Email Marketing via Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=app-password
SMTP_FROM=tu@email.com

# Meta Webhook (for receiving inbound messages from IG/FB/WA)
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
