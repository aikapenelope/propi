# Database
# DATABASE_URL: PgBouncer (port 6432) for runtime queries
# DATABASE_DIRECT_URL: Direct Postgres (port 5432) for schema sync on deploy
DATABASE_URL=postgresql://platform:PASSWORD@10.0.1.20:6432/propi
DATABASE_DIRECT_URL=postgresql://platform:PASSWORD@10.0.1.20:5432/propi

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# MinIO / S3 Storage
S3_ENDPOINT=http://10.0.1.20:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_MEDIA_BUCKET=propi-media
S3_DOCS_BUCKET=propi-documents

# Email (Resend - free tier: 3,000 emails/month)
RESEND_API_KEY=re_...
MAIL_FROM=Propi <noreply@propi.aikalabs.cc>

# Meta (Instagram, Facebook, WhatsApp)
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
META_APP_SECRET=your-meta-app-secret

# Groq AI (free tier: 1,000 requests/day)
GROQ_API_KEY=gsk_...

# MercadoLibre (create app at developers.mercadolibre.com.ve)
ML_APP_ID=your-app-id
ML_SECRET_KEY=your-secret-key

# Cron job protection
CRON_SECRET=your-random-cron-secret
